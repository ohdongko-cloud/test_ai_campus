# 이 파일을 keystore.properties 로 복사한 뒤 실제 값으로 채우세요.
# keystore.properties 는 절대 git에 커밋하지 마세요(.gitignore에 등록됨).
#
# storeFile 은 android/app/ 기준 상대 경로 또는 절대 경로.
# 권장 위치: android/app/upload-keystore.jks

storeFile=upload-keystore.jks
storePassword=<여기에 keystore 비밀번호>
keyAlias=upload
keyPassword=<여기에 키 비밀번호>
