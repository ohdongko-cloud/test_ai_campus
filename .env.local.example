# ─────────────────────────────────────────────
# Neon DB 연결 문자열 (필수)
# Neon 대시보드 > Connection Details > Connection string (Pooled)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/dbname?sslmode=require

# ─────────────────────────────────────────────
# 관리자 페이지 비밀번호 (필수, 운영에선 강한 값 필수)
# 운영 환경에서 'admin2026'(기본값)이면 503 반환.
# ─────────────────────────────────────────────
ADMIN_PASSWORD=change-me-to-strong-random-string

# 마스터 관리자 이메일(쉼표 구분, lowercase).
# 여기 등록된 회원은 회원 로그인만으로 마스터 관리자 권한 자동 부여.
# 위임 관리자 임명/해지, 모든 설정 변경 권한 보유.
MASTER_ADMIN_EMAILS=admin@example.com

# ─────────────────────────────────────────────
# 회원가입 도메인 예외 허용(쉼표 구분, lowercase). 선택.
# 기본은 @eland.co.kr 만 허용. 한시적 테스터 이메일을 여기 추가.
# NEXT_PUBLIC_ 접두사 — 클라이언트 사전검증과 서버 최종검증이 공유.
# ─────────────────────────────────────────────
NEXT_PUBLIC_EMAIL_DOMAIN_EXCEPTIONS=tester@example.com

# ─────────────────────────────────────────────
# Vercel Blob (첨부파일/스테이지 이미지 저장). Storage 연결 시 자동 주입.
# ─────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# ─────────────────────────────────────────────
# JWT 서명용 비밀 키 (필수, 32바이트 이상 권장)
# 생성 예시:
#   - openssl rand -hex 32
#   - node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────
JWT_SECRET=change-me-to-64-hex-characters

# ─────────────────────────────────────────────
# Resend (이메일 인증 메일 발송)
# https://resend.com/api-keys
# ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxx

# 발신 표시. 무료 옵션: 'AI 캠퍼스 <onboarding@resend.dev>'
# 정식: 커스텀 도메인 등록 후 'AI 캠퍼스 <no-reply@eland.co.kr>'
EMAIL_FROM=AI 캠퍼스 <onboarding@resend.dev>

# ─────────────────────────────────────────────
# Upstash Redis (선택, 강력 권장)
# 미설정 시 in-memory 폴백 — Vercel serverless에선 불완전
# https://upstash.com 가입 → Create Database
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxx

# ─────────────────────────────────────────────
# 데모용 테스트 계정 (선택, 시연 끝나면 env 제거 권장)
# 세 변수 모두 설정 + 현재시각 < TEST_ACCOUNT_EXPIRES_AT 일 때만 활성.
# 활성 시: 해당 이메일은 Resend 호출 안 함 + 고정 코드로 통과.
# 만료 시: cron(/api/cron/cleanup-test-account)이 매일 00:00 UTC에
# 해당 user row 자동 삭제.
# ─────────────────────────────────────────────
TEST_ACCOUNT_EMAIL=test@eland.co.kr
TEST_ACCOUNT_CODE=000000
TEST_ACCOUNT_EXPIRES_AT=2026-06-02T23:59:59Z

# Vercel Cron 인증 시크릿 (Vercel이 자동으로 Authorization 헤더에 부착)
# 생성: openssl rand -hex 32
CRON_SECRET=change-me-to-64-hex-characters

# ─────────────────────────────────────────────
# SSO 허브(IdP) — AI캠퍼스를 사내 앱 중앙 로그인 허브로.
# 키쌍 생성(무료, Node crypto):
#   node -e "const {generateKeyPairSync}=require('crypto');const {privateKey,publicKey}=generateKeyPairSync('rsa',{modulusLength:2048,publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}});require('fs').writeFileSync('sso_private.pem',privateKey);require('fs').writeFileSync('sso_public.pem',publicKey);console.log('done')"
# PEM은 멀티라인 그대로 또는 \n-escaped 단일행 둘 다 지원(코드에서 복원).
# ─────────────────────────────────────────────
# RS256 개인키(PKCS#8 PEM) — 허브 전용. 절대 노출/스포크 배포 금지.
SSO_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...REPLACE_ME...\n-----END PRIVATE KEY-----\n"
# RS256 공개키(SPKI PEM) — JWKS 생성용(공개키이므로 노출 무방).
SSO_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMII...REPLACE_ME...\n-----END PUBLIC KEY-----\n"
# 현재 키 식별자(kid, 회전 추적). 예: 2026-06-key1
SSO_KID=2026-06-key1
# iss 클레임(발급자). 운영 URL.
SSO_ISSUER=https://retail-ai-campus.vercel.app

# (선택) DB `sso_clients` 미사용 시 env 폴백 레지스트리. 정확매칭 베이스 URL만.
# 스포크 실제 URL은 미확정(Q6) — 받는 대로 등록. 예:
# SSO_CLIENTS_JSON=[{"app":"web-fashion","name":"의류CU","redirectUris":["https://eland-apparel.vercel.app/sso/callback"]}]
SSO_CLIENTS_JSON=

# (선택, 비권장) HS256 폴백 공유 시크릿. RS256 지연 시 단기 브리지용.
SSO_SHARED_SECRET=

# (개발 전용) http/localhost redirect_uri 허용 플래그. 운영에서는 무시됨.
# SSO_ALLOW_INSECURE_REDIRECT=1
