# ─────────────────────────────────────────────
# Neon DB 연결 문자열 (필수)
# Neon 대시보드 > Connection Details > Connection string (Pooled)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/dbname?sslmode=require

# ─────────────────────────────────────────────
# 관리자 페이지 비밀번호 (필수, 운영에선 강한 값 필수)
# 운영 환경에서 'admin2026'(기본값)이면 503 반환.
# ─────────────────────────────────────────────
ADMIN_PASSWORD=change-me-to-strong-random-string

# ─────────────────────────────────────────────
# JWT 서명용 비밀 키 (필수, 32바이트 이상 권장)
# 생성 예시:
#   - openssl rand -hex 32
#   - node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────
JWT_SECRET=change-me-to-64-hex-characters

# ─────────────────────────────────────────────
# Resend (이메일 인증 메일 발송)
# https://resend.com/api-keys
# ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxx

# 발신 표시. 무료 옵션: 'AI 캠퍼스 <onboarding@resend.dev>'
# 정식: 커스텀 도메인 등록 후 'AI 캠퍼스 <no-reply@eland.co.kr>'
EMAIL_FROM=AI 캠퍼스 <onboarding@resend.dev>

# ─────────────────────────────────────────────
# Upstash Redis (선택, 강력 권장)
# 미설정 시 in-memory 폴백 — Vercel serverless에선 불완전
# https://upstash.com 가입 → Create Database
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxx
